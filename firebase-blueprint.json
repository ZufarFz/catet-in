{
  "entities": {
    "Instansi": {
      "title": "Instansi",
      "description": "Dynamic tenants custom Firebase configurations",
      "type": "object",
      "properties": {
        "instansiName": { "type": "string", "description": "Name of institution" },
        "apiKey": { "type": "string" },
        "appId": { "type": "string" },
        "authDomain": { "type": "string" },
        "messagingSenderId": { "type": "string" },
        "projectId": { "type": "string" },
        "storageBucket": { "type": "string" },
        "firestoreDatabaseId": { "type": "string" }
      },
      "required": ["instansiName", "apiKey", "appId", "authDomain", "messagingSenderId", "projectId", "storageBucket"]
    },
    "User": {
      "title": "User",
      "description": "User account for authentication and role management",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique username" },
        "password": { "type": "string", "description": "User password" },
        "full_name": { "type": "string", "description": "Full display name" },
        "role": { "type": "string", "description": "User role: Admin, Ketua, Wakil, Bendahara, Viewer" },
        "original_role": { "type": "string", "description": "Original role string" },
        "instansi": { "type": "string", "description": "Institution name" },
        "web_access": { "type": "string", "description": "Comma-separated access modules: bendahara,absensi" }
      },
      "required": ["username", "password", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial ledger transaction entry",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID format MBR- or TX-" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "formattedDate": { "type": "string", "description": "DD/MM/YY" },
        "description": { "type": "string", "description": "Transaction details" },
        "type": { "type": "string", "enum": ["masuk", "keluar"] },
        "category": { "type": "string", "description": "Transaction category" },
        "project_name": { "type": "string", "description": "Project name or KAS UMUM" },
        "debit": { "type": "number" },
        "credit": { "type": "number" },
        "balance": { "type": "number" },
        "amount": { "type": "number" },
        "created_at": { "type": "string" },
        "created_by": { "type": "string" },
        "created_by_role": { "type": "string" },
        "edit_version": { "type": "number" },
        "is_approve": { "type": "boolean" },
        "approve_by": { "type": "string" },
        "approve_date": { "type": "string" },
        "approver_role": { "type": "string" }
      },
      "required": ["id", "date", "description", "type", "category", "project_name", "amount", "created_at"]
    },
    "DeletedTransaction": {
      "title": "DeletedTransaction",
      "description": "Financial transaction deletion audit entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "formattedDate": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "project_name": { "type": "string" },
        "debit": { "type": "number" },
        "credit": { "type": "number" },
        "balance": { "type": "number" },
        "amount": { "type": "number" },
        "created_at": { "type": "string" },
        "created_by": { "type": "string" },
        "created_by_role": { "type": "string" },
        "edit_version": { "type": "number" },
        "delete_reason": { "type": "string" },
        "deleted_at": { "type": "string" },
        "delete_by": { "type": "string" }
      },
      "required": ["id", "delete_reason", "deleted_at", "delete_by"]
    },
    "EditHistory": {
      "title": "EditHistory",
      "description": "Financial transaction modification audit entry",
      "type": "object",
      "properties": {
        "history_id": { "type": "string" },
        "transaction_id": { "type": "string" },
        "project_name": { "type": "string" },
        "type": { "type": "string" },
        "old_description": { "type": "string" },
        "new_description": { "type": "string" },
        "old_value": { "type": "number" },
        "new_value": { "type": "number" },
        "edited_at": { "type": "string" },
        "edited_by": { "type": "string" },
        "version_number": { "type": "number" }
      },
      "required": ["history_id", "transaction_id", "project_name", "type", "old_description", "new_description", "old_value", "new_value", "edited_at", "edited_by", "version_number"]
    },
    "Project": {
      "title": "Project",
      "description": "Project definition for finance segmentation",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "created_at": { "type": "string" },
        "status": { "type": "string" },
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string" },
        "approver_role": { "type": "string" }
      },
      "required": ["name", "created_at", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Transaction category definition",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Approval": {
      "title": "Approval",
      "description": "Month approval period status",
      "type": "object",
      "properties": {
        "period_id": { "type": "string" },
        "project_name": { "type": "string" },
        "approved_by": { "type": "string" },
        "approve_date": { "type": "string" },
        "approver_role": { "type": "string" }
      },
      "required": ["period_id", "project_name", "approved_by", "approve_date"]
    },
    "AbsensiMember": {
      "title": "AbsensiMember",
      "description": "Member profile for attendance tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "desa_id": { "type": "string" },
        "kelompok_id": { "type": "string" },
        "age_category_id": { "type": "string" },
        "nama_lengkap": { "type": "string" },
        "tempat_lahir": { "type": "string" },
        "tanggal_lahir": { "type": "string" },
        "no_hp_anggota: ": { "type": "string" },
        "jenis_kelamin": { "type": "string" },
        "nama_ortu": { "type": "string" },
        "no_hp_ortu": { "type": "string" },
        "pekerjaan_ortu": { "type": "string" },
        "alamat_rumah": { "type": "string" },
        "pendidikan": { "type": "string" },
        "kelas": { "type": "string" }
      },
      "required": ["id", "desa_id", "kelompok_id", "age_category_id", "nama_lengkap"]
    },
    "AttendanceLog": {
      "title": "AttendanceLog",
      "description": "Specific attendance transaction entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "ageName": { "type": "string" },
        "kelompokName": { "type": "string" },
        "desaName": { "type": "string" },
        "date": { "type": "string" },
        "dateInput": { "type": "string" },
        "status": { "type": "string", "enum": ["Hadir", "Izin", "Sakit", "Alpa"] },
        "note": { "type": "string" }
      },
      "required": ["id", "memberId", "memberName", "date", "status"]
    },
    "DesaData": {
      "title": "DesaData",
      "description": "Desa (village) core information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama_desa": { "type": "string" },
        "pimpinan": { "type": "string" },
        "alamat": { "type": "string" }
      },
      "required": ["id", "nama_desa"]
    },
    "KelompokData": {
      "title": "KelompokData",
      "description": "Kelompok (group) core information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama_kelompok": { "type": "string" },
        "pimpinan": { "type": "string" },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "nama_kelompok"]
    },
    "AgeCategoryData": {
      "title": "AgeCategoryData",
      "description": "Age bracket/category core information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile definitions list"
    },
    "/instansi/{instansiId}": {
      "schema": "Instansi",
      "description": "Multi-tenant dynamic Firebase workspace configuration registers"
    },
    "/treasurer-web/data/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial ledger transactions list"
    },
    "/treasurer-web/data/deletedTransactions/{deletedId}": {
      "schema": "DeletedTransaction",
      "description": "Audit record of deleted ledger entries"
    },
    "/treasurer-web/data/editHistory/{historyId}": {
      "schema": "EditHistory",
      "description": "Audit record of transaction edits"
    },
    "/treasurer-web/data/projects/{projectId}": {
      "schema": "Project",
      "description": "Active finance segmented projects"
    },
    "/treasurer-web/data/categories/{categoryId}": {
      "schema": "Category",
      "description": "Finance tags / categories list"
    },
    "/treasurer-web/data/approvals/{approvalId}": {
      "schema": "Approval",
      "description": "Monthly period structural approvals"
    },
    "/attendance-web/data/members/{memberId}": {
      "schema": "AbsensiMember",
      "description": "Attendance registry of individual members"
    },
    "/attendance-web/data/attendanceLogs/{logId}": {
      "schema": "AttendanceLog",
      "description": "Attendance transactions list"
    },
    "/attendance-web/data/desas/{desaId}": {
      "schema": "DesaData",
      "description": "Master list of registered villages"
    },
    "/attendance-web/data/kelompoks/{kelompokId}": {
      "schema": "KelompokData",
      "description": "Master list of groups"
    },
    "/attendance-web/data/ageCategories/{ageCategoryId}": {
      "schema": "AgeCategoryData",
      "description": "Master list of age ranges"
    }
  }
}
